<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ns_background">

    <View
        android:id="@+id/topHeaderBackground"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_dashboard_header"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/ns_background"
        android:elevation="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/ns_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Sincronizando dados..."
            android:textColor="@color/ns_text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshDashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollDashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="90dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guide_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_begin="24dp" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guide_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_end="24dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="@id/guide_start">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/dashboard_logo_description"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo_nextstep" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/dashboard_header_default"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    app:layout_constraintTop_toTopOf="@id/cvAvatar"
                    app:layout_constraintStart_toEndOf="@id/cvAvatar"
                    app:layout_constraintEnd_toStartOf="@id/btnToggleBalance" />

                <ImageButton
                    android:id="@+id/btnToggleBalance"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_toggle_balance"
                    android:src="@drawable/ic_eye"
                    android:tint="@color/white"
                    android:padding="8dp"
                    app:layout_constraintTop_toTopOf="@id/cvAvatar"
                    app:layout_constraintEnd_toEndOf="@id/guide_end"
                    app:layout_constraintBottom_toBottomOf="@id/cvAvatar" />

                <TextView
                    android:id="@+id/tvSubHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/dashboard_subheader_default"
                    android:textColor="@color/ns_header_text_soft"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/tvHeader"
                    app:layout_constraintStart_toEndOf="@id/cvAvatar"
                    app:layout_constraintEnd_toEndOf="@id/guide_end" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSaldo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardBackgroundColor="@color/ns_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toBottomOf="@id/cvAvatar"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_soft_pill"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:text="@string/dashboard_summary_label"
                            android:textColor="@color/ns_primary_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="@string/dashboard_balance_label"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSaldo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/currency_zero"
                            android:textColor="@color/ns_text_primary"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.03" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/dashboard_summary_subtitle"
                            android:textColor="@color/ns_text_hint"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Actions Row -->
                <LinearLayout
                    android:id="@+id/rowQuickActions"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/cardSaldo"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <!-- Nova Receita -->
                    <LinearLayout
                        android:id="@+id/quickActionIncome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@color/ns_success_light"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_add"
                                android:importantForAccessibility="no"
                                android:tint="@color/ns_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/quick_action_income"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Nova Despesa -->
                    <LinearLayout
                        android:id="@+id/quickActionExpense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@color/ns_error_light"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_remove"
                                android:importantForAccessibility="no"
                                android:tint="@color/ns_error" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/quick_action_expense"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Agenda -->
                    <LinearLayout
                        android:id="@+id/quickActionAgenda"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@color/ns_primary_light"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_clock"
                                android:importantForAccessibility="no"
                                android:tint="@color/ns_primary" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/quick_action_agenda"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Chat IA -->
                    <LinearLayout
                        android:id="@+id/quickActionAI"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@color/ns_secondary_light"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_nav_chatbot"
                                android:importantForAccessibility="no"
                                android:tint="@color/ns_secondary" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/quick_action_ai"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowKpis"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    app:layout_constraintTop_toBottomOf="@id/rowQuickActions"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardBackgroundColor="@color/ns_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dashboard_income_label"
                                android:textColor="@color/ns_text_secondary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvReceita"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/currency_zero"
                                android:textColor="@color/ns_success"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="@color/ns_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dashboard_expense_label"
                                android:textColor="@color/ns_text_secondary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDespesa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/currency_zero"
                                android:textColor="@color/ns_error"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Comparativo mensal -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardComparison"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/ns_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toBottomOf="@id/rowKpis"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_comparison_title"
                            android:textColor="@color/ns_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dashboard_income_label"
                                    android:textColor="@color/ns_text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvComparisonIncomeChange"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/ns_success"
                                    android:text="—" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/ns_border"
                                android:layout_marginHorizontal="12dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dashboard_expense_label"
                                    android:textColor="@color/ns_text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvComparisonExpenseChange"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/ns_error"
                                    android:text="—" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMei"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/ns_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toBottomOf="@id/cardComparison"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvLabelMei"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_mei_limit_label"
                            android:textColor="@color/ns_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/dashboard_mei_limit_subtitle"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="13sp" />

                        <ProgressBar
                            android:id="@+id/pbMeiLimit"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="16dp"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/ns_surface_soft"
                            android:progressTint="@color/ns_primary" />

                        <TextView
                            android:id="@+id/tvMeiProgressValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/dashboard_mei_progress_default"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="63%% do limite • R$ 51.000,00 de R$ 81.000,00" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Meta mensal -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGoal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/ns_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toBottomOf="@id/cardMei"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_goal_title"
                            android:textColor="@color/ns_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/pbGoal"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="14dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/ns_primary"
                            android:progressBackgroundTint="@color/ns_border" />

                        <TextView
                            android:id="@+id/tvGoalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="13sp"
                            android:text="—" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGraph"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/ns_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toBottomOf="@id/cardGoal"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_cashflow_title"
                            android:textColor="@color/ns_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/dashboard_cashflow_subtitle"
                            android:textColor="@color/ns_text_secondary"
                            android:textSize="14sp" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChartDashboard"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:layout_marginTop="20dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/rowTransactionsHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toBottomOf="@id/cardGraph"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end">

                    <TextView
                        android:id="@+id/tvListaTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dashboard_transactions_title"
                        android:textColor="@color/ns_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVerTodas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_see_all"
                        android:textColor="@color/ns_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="8dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTransactions"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_transaction"
                    app:layout_constraintTop_toBottomOf="@id/rowTransactionsHeader"
                    app:layout_constraintStart_toStartOf="@id/guide_start"
                    app:layout_constraintEnd_toEndOf="@id/guide_end" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="@string/dashboard_add_transaction_description"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/ns_primary_dark"
        app:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ns_surface"
        app:elevation="24dp"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
