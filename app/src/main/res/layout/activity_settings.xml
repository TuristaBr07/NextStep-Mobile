<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configurações"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meu Perfil"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#46453B"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etProfileName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nome Completo"
            android:backgroundTint="#E0E0E0"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etProfileCompany"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nome da Empresa (Opcional)"
            android:backgroundTint="#E0E0E0"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Salvar Perfil"
            android:backgroundTint="#46453B"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gerenciar Categorias"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#46453B"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Spinner
                android:id="@+id/spinnerCatType"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:entries="@array/transaction_types"/>

            <EditText
                android:id="@+id/etNewCatName"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Nova Categoria"
                android:backgroundTint="#E0E0E0"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnAddCat"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:text="ADD"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategoriesSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Sair da Conta"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>