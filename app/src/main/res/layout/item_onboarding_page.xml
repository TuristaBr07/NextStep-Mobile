<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="40dp">

    <LinearLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_onboarding_icon"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivOnboardingIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@null"
            app:tint="@color/ns_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvOnboardingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:textColor="@color/ns_text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:lineSpacingExtra="2dp" />

    <TextView
        android:id="@+id/tvOnboardingDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:textColor="@color/ns_text_secondary"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
